<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_studyflow"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="18dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/notification_settings_title"
            android:textColor="@color/studyflow_ink"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/notification_settings_subtitle"
            android:textColor="@color/studyflow_muted_ink" />

        <ProgressBar
            android:id="@+id/loadingProgressBar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="16dp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/errorTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_studyflow_card"
            android:padding="14dp"
            android:textColor="@color/studyflow_error"
            android:visibility="gone" />

        <TextView
            android:id="@+id/messageTextView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:background="@drawable/bg_studyflow_card"
            android:padding="14dp"
            android:textColor="@color/studyflow_blue"
            android:visibility="gone" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_studyflow_card"
            android:elevation="3dp"
            android:orientation="vertical"
            android:padding="18dp">

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/classRemindersSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/notif_class_reminders" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/deadlineAlertsSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/notif_deadline_alerts" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/focusRemindersSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/notif_focus_reminders" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/groupChatSwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/notif_group_chat" />

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/dailySummarySwitch"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/notif_daily_summary" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/summaryTimeLayout"
                style="@style/Widget.StudyFlow.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/notif_summary_time">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/summaryTimeEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:focusable="false"
                    android:inputType="none" />
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
