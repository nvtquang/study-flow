<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="TextAppearance.StudyFlow.Title" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="android:textColor">@color/studyflow_ink</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="TextAppearance.StudyFlow.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">@color/studyflow_muted_ink</item>
        <item name="android:fontFamily">sans</item>
    </style>

    <style name="Widget.StudyFlow.Button" parent="Widget.MaterialComponents.Button">
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@color/selector_studyflow_button</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="rippleColor">@color/studyflow_lavender_light</item>
    </style>

    <style name="Widget.StudyFlow.TextInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/selector_studyflow_input_stroke</item>
        <item name="hintTextColor">@color/studyflow_muted_ink</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxBackgroundColor">@color/studyflow_surface_alt</item>
    </style>

    <style name="Widget.StudyFlow.FloatingActionButton" parent="Widget.MaterialComponents.FloatingActionButton">
        <item name="backgroundTint">@color/studyflow_blue</item>
        <item name="tint">@color/white</item>
        <item name="rippleColor">@color/studyflow_lavender_light</item>
        <item name="elevation">8dp</item>
    </style>

    <style name="Widget.StudyFlow.BottomNavigation" parent="Widget.MaterialComponents.BottomNavigationView">
        <item name="itemIconTint">@color/selector_bottom_nav</item>
        <item name="itemTextColor">@color/selector_bottom_nav</item>
        <item name="itemRippleColor">@color/studyflow_lavender_light</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>
</resources>
